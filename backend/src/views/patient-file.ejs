<!DOCTYPE html>
<html lang="<%= lang === 'ar' ? 'ar' : 'en' %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= t('patients.download.title', fullname) %> - <%= fullname %></title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: <%= dir === 'rtl' ? '"Cairo", "Traditional Arabic", Arial' : '"Segoe UI", Arial' %>, sans-serif;
    background: #f0f2f5;
    padding: 24px;
    color: #222;
  }

  .form-container {
    max-width: 850px;
    margin: auto;
    background: #fff;
    padding: 40px 35px;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    position: relative;
    overflow: hidden;
  }

  .watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.06;
    width: 350px;
    pointer-events: none;
    z-index: 0;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .header .logo {
    height: 55px;
  }

  hr {
    border: none;
    border-top: 2px solid #1a5276;
    margin-bottom: 18px;
    position: relative;
    z-index: 1;
  }

  .title {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a5276;
    position: relative;
    z-index: 1;
  }

  .personal-info {
    border: 1.5px solid #333;
    border-radius: 10px;
    padding: 18px 20px;
    display: grid;
    grid-template-columns: repeat(<%= dir === 'rtl' ? 2 : 4 %>, 1fr);
    gap: 10px 16px;
    margin-bottom: 22px;
    font-size: 14px;
    position: relative;
    z-index: 1;
    background: #fafafa;
  }

  .personal-info .field {
    display: flex;
    align-items: center;
  }

  .personal-info .field.full {
    grid-column: 1 / -1;
  }

  .personal-info label {
    font-weight: 700;
    white-space: nowrap;
    margin-<%= dir === 'rtl' ? 'left' : 'right' %>: 6px;
    color: #1a5276;
    font-size: 13px;
  }

  .underline {
    flex: 1;
    border-bottom: 1.5px solid #333;
    min-height: 20px;
    padding: 0 4px;
    display: flex;
    align-items: center;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-weight: 500;
  }

  .section {
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .section > label {
    font-weight: 700;
    display: block;
    margin-bottom: 4px;
    color: #1a5276;
    font-size: 14px;
  }

  .section .line {
    border-bottom: 1.5px solid #333;
    height: 22px;
    margin-bottom: 4px;
  }

  .signature {
    margin-top: 28px;
    position: relative;
    z-index: 1;
  }

  .signature label {
    font-weight: 700;
    display: block;
    margin-bottom: 4px;
    color: #1a5276;
    font-size: 14px;
  }

  .signature .line {
    border-bottom: 1.5px solid #333;
    height: 22px;
    width: 280px;
  }

  .bottom-border {
    margin-top: 24px;
    border-top: 2px solid #1a5276;
    position: relative;
    z-index: 1;
  }

  .footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 12px;
    color: #555;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .footer img {
    width: 18px;
    height: 18px;
  }

  .footer .sep {
    color: #ccc;
    margin: 0 4px;
  }

  .print-btn {
    display: block;
    margin: 20px auto 0;
    padding: 10px 32px;
    background: #1a5276;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 15px;
    cursor: pointer;
    position: relative;
    z-index: 1;
  }

  .print-btn:hover {
    background: #154360;
  }

  @media print {
    body {
      background: #fff;
      padding: 0;
    }
    .form-container {
      box-shadow: none;
      margin: 0;
      padding: 24px 20px;
      max-width: 100%;
      border-radius: 0;
    }
    .watermark { opacity: 0.04; width: 280px; }
    .personal-info { background: none; }
    .print-btn { display: none; }
  }

  @media (max-width: 600px) {
    body { padding: 12px; }
    .form-container { padding: 20px 16px; }
    .personal-info { grid-template-columns: 1fr; }
    .header .logo { height: 40px; }
  }
</style>
</head>
<body>

<div class="form-container">
    <img src="/assets/img/logos/center.png" class="watermark" alt="">

  <div class="header">
    <img src="/assets/img/logos/samaE.png" class="logo" alt="SAMA">
    <img src="/assets/img/logos/center.png" class="logo" alt="Center">
    <img src="/assets/img/logos/samaA.png" class="logo" alt="سما">
  </div>

  <hr>

  <h4 class="title"><%= t('patients.download.title', fullname) %></h4>

  <div class="personal-info">
    <div class="field">
      <label><%= t('patients.add.form.name') %>:</label>
      <span class="underline"><%= fullname %></span>
    </div>
    <div class="field">
      <label><%= t('patients.add.form.gender') %>:</label>
      <span class="underline"><%= gender %></span>
    </div>
    <div class="field">
      <label><%= t('patients.add.form.age') %>:</label>
      <span class="underline"><%= age %></span>
    </div>
    <div class="field">
      <label><%= t('patients.add.form.date') %>:</label>
      <span class="underline"><%= date %></span>
    </div>
    <div class="field">
      <label><%= t('patients.col.phone') %>:</label>
      <span class="underline" dir="ltr"><%= phone %></span>
    </div>
    <div class="field">
      <label><%= t('patients.add.form.examType') %>:</label>
      <span class="underline"><%= examType %></span>
    </div>
    <div class="field">
      <label>ID:</label>
      <span class="underline"><%= serialNumber %></span>
    </div>
    <div class="field">
      <label><%= t('patients.add.form.price') %>:</label>
      <span class="underline"><%= price %></span>
    </div>
  </div>

  <div class="section">
    <label><%= t('patients.download.diagnosis') %></label>
    <div class="line"></div>
  </div>

  <div class="section">
    <label><%= t('patients.download.history') %></label>
    <div class="line"></div>
    <div class="line"></div>
    <div class="line"></div>
  </div>

  <div class="section">
    <label><%= t('patients.download.chiefComplaint') %></label>
    <div class="line"></div>
    <div class="line"></div>
    <div class="line"></div>
  </div>

  <div class="section">
    <label><%= t('patients.download.notes') %></label>
    <div class="line"></div>
    <div class="line"></div>
    <div class="line"></div>
  </div>

  <div class="section">
    <label><%= t('patients.download.treatmentPlan') %></label>
    <div class="line"></div><div class="line"></div><div class="line"></div>
    <div class="line"></div><div class="line"></div><div class="line"></div>
    <div class="line"></div><div class="line"></div><div class="line"></div>
  </div>

  <div class="signature">
    <label><%= t('patients.download.doctorSignature') %></label>
    <div class="line"></div>
  </div>

  <div class="bottom-border"></div>

  <div class="footer">
    <img src="/assets/img/mail.png" alt="Email">
    sama.center.pt@gmail.com
    <span class="sep">|</span>
    <img src="/assets/img/telephone.png" alt="Phone">
    +967778199978 &nbsp; +967736677739
    <span class="sep">|</span>
    <img src="/assets/img/location.png" alt="Location">
    sama-center-website.netlify.app
  </div>

  <button class="print-btn" onclick="window.print()">طباعة</button>
</div>

</body>
</html>
