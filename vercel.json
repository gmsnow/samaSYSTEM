{
  "services": {
    "server": {
      "root": "backend",
      "entrypoint": "dist/index.js",
      "buildCommand": "npm ci && npm run build"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "server"
      }
    }
  ]
}
