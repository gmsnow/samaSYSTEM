{
  "installCommand": "cd frontend && npm ci && cd ../backend && npm ci",
  "builds": [
    {
      "src": "backend/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["frontend/dist/**"]
      }
    }
  ],
  "routes": [
    { "source": "/(.*)", "dest": "backend/index.ts" }
  ]
}
